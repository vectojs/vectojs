# Dependencies
node_modules/

# Build output
dist/
build/
*.tgz

# Cache (Vite / Vitest / tsbuildinfo)
.vite/
.cache/
*.tsbuildinfo

# Test coverage
coverage/

# Benchmark output
scripts/.bench-results.json
scripts/.compare-results.json

# Rust / WASM core (crates/vectojs-core-rs)
# The .wasm asset is built by crates/vectojs-core-rs/build.sh in CI and
# published to npm — never committed. Contributors touching only TypeScript
# have no Rust toolchain, and the JS path is a permanent fallback.
crates/**/target/
packages/core/src/wasm/*.wasm

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local / env
*.local
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
Thumbs.db

# Brainstorming sessions
.superpowers/

# Local agent skill installs
.claude/skills/
.agents/
.husky/

# core-wasm benchmark build artifacts + results (page/ is generated by build.ts)
benchmarks/core-wasm/page/index.html
benchmarks/core-wasm/page/*.wasm
benchmarks/*/results/

# scene-wasm benchmark build artifacts + results
benchmarks/scene-wasm/page/index.html
benchmarks/scene-wasm/page/*.wasm

# anim-wasm benchmark build artifacts + results
benchmarks/anim-wasm/page/index.html
benchmarks/anim-wasm/page/*.wasm
