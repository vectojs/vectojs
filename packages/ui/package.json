{
  "name": "@vectojs/ui",
  "version": "1.11.3",
  "publishConfig": {
    "access": "public"
  },
  "description": "High-level canvas UI components (Text, Button, Link) for VectoJS — rendered to canvas with an accessibility/automation shadow layer.",
  "keywords": [
    "canvas",
    "ui",
    "components",
    "accessibility",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vectojs/vectojs.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/vectojs/vectojs/issues"
  },
  "homepage": "https://github.com/vectojs/vectojs#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./input": {
      "types": "./dist/Input.d.ts",
      "import": "./dist/Input.mjs",
      "require": "./dist/Input.js"
    },
    "./text": {
      "types": "./dist/Text.d.ts",
      "import": "./dist/Text.mjs",
      "require": "./dist/Text.js"
    },
    "./measure": {
      "types": "./dist/measure.d.ts",
      "import": "./dist/measure.mjs",
      "require": "./dist/measure.js"
    },
    "./context-menu": {
      "types": "./dist/ContextMenu.d.ts",
      "import": "./dist/ContextMenu.mjs",
      "require": "./dist/ContextMenu.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build-worker.js && (cd ../core && bun run build) && tsup src/index.ts --format cjs,esm --clean && tsup src/Input.ts --format cjs,esm && tsup src/Text.ts --format cjs,esm && tsup src/measure.ts --format cjs,esm && tsup src/ContextMenu.ts --format cjs,esm && tsc -p tsconfig.build.json && bun run verify:lightweight-entries",
    "test": "vitest run",
    "verify:lightweight-entries": "node scripts/verify-lightweight-entries.mjs"
  },
  "dependencies": {
    "marked": "^18.0.6",
    "mathjax-full": "^3.2.2"
  },
  "peerDependencies": {
    "@vectojs/core": ">=1.8.0 <2.0.0"
  },
  "devDependencies": {
    "@vectojs/core": "workspace:*",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tsup": "^8.3.5",
    "vitest": "^4.1.10"
  }
}
