{
  "name": "@vecto-ui/ui",
  "version": "0.3.1",
  "description": "High-level canvas UI components (Text, Button, Link) for VectoUI — rendered to canvas with an accessibility/automation shadow layer.",
  "keywords": [
    "canvas",
    "ui",
    "components",
    "accessibility",
    "zero-dom",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xuepoo/vecto-ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/Xuepoo/vecto-ui/issues"
  },
  "homepage": "https://github.com/Xuepoo/vecto-ui#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run"
  },
  "dependencies": {
    "@vecto-ui/core": "^0.7.0",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "@types/marked": "^6.0.0",
    "jsdom": "^29.1.1",
    "tsup": "^8.3.5",
    "vitest": "^4.1.9"
  }
}
