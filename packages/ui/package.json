{
  "name": "@vectojs/ui",
  "version": "1.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "High-level canvas UI components (Text, Button, Link) for VectoJS — rendered to canvas with an accessibility/automation shadow layer.",
  "keywords": [
    "canvas",
    "ui",
    "components",
    "accessibility",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vectojs/vectojs.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/vectojs/vectojs/issues"
  },
  "homepage": "https://github.com/vectojs/vectojs#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "(cd ../core && bun run build) && tsup src/index.ts --format cjs,esm --clean && tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "marked": "^18.0.5"
  },
  "peerDependencies": {
    "@vectojs/core": ">=0.1.0"
  },
  "devDependencies": {
    "@vectojs/core": "workspace:*",
    "jsdom": "^29.1.1",
    "tsup": "^8.3.5",
    "vitest": "^4.1.9"
  }
}
