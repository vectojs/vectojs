{
  "name": "@vectojs/layout",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Standalone text/box layout engine for VectoJS: line breaking, BiDi-aware inline layout, exclusion flow, glyph measurement, and an off-main-thread layout worker.",
  "keywords": [
    "layout-engine",
    "line-breaking",
    "text-layout",
    "bidi",
    "vectojs",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vectojs/vectojs.git",
    "directory": "packages/layout"
  },
  "bugs": {
    "url": "https://github.com/vectojs/vectojs/issues"
  },
  "homepage": "https://github.com/vectojs/vectojs#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "(cd ../text && bun run build) && node scripts/build-worker.js && tsup && tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@vectojs/text": "^0.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "prettier": "^3.9.5",
    "tsup": "^8.3.5",
    "vitest": "^4.1.10"
  }
}
