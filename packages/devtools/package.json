{
  "name": "@vectojs/devtools",
  "version": "0.4.3",
  "publishConfig": {
    "access": "public"
  },
  "description": "In-page Virtual Math Tree inspector for VectoJS scenes — entity picking, live tree view, and state readout, itself rendered with VectoJS",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./headless": {
      "types": "./dist/headless.d.ts",
      "import": "./dist/headless.mjs",
      "require": "./dist/headless.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "(cd ../core && bun run build) && (cd ../ui && bun run build) && tsup src/index.ts --format cjs,esm --clean && tsup src/headless.ts --format cjs,esm && tsc -p tsconfig.build.json && bun run verify:headless-entry",
    "test": "vitest run",
    "test:e2e": "bun e2e/event-trace.e2e.ts",
    "verify:headless-entry": "node scripts/verify-headless-entry.mjs"
  },
  "peerDependencies": {
    "@vectojs/core": ">=1.0.0 <2.0.0",
    "@vectojs/ui": ">=1.0.0 <2.0.0"
  },
  "peerDependenciesMeta": {
    "@vectojs/ui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vectojs/core": "workspace:*",
    "@vectojs/ui": "workspace:*",
    "puppeteer-core": "^25.3.0",
    "tsup": "^8.3.5",
    "vitest": "^4.1.10",
    "jsdom": "^29.1.1"
  }
}
