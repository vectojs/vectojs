{
  "name": "@vecto-ui/core",
  "version": "0.1.1",
  "description": "A zero-DOM, Canvas 2D Entity Component System (ECS) rendering framework — 60 FPS with 100,000+ entities.",
  "keywords": [
    "canvas",
    "ecs",
    "fourier",
    "spline",
    "rendering",
    "60fps",
    "typescript",
    "vectorization"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xuepoo/vecto-ui.git"
  },
  "bugs": {
    "url": "https://github.com/Xuepoo/vecto-ui/issues"
  },
  "homepage": "https://github.com/Xuepoo/vecto-ui#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "tsup": "^8.3.5",
    "vitest": "^4.1.9"
  }
}
