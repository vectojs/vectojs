{
  "name": "@vectojs/graph3d",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "3D force-directed graph visualization for VectoJS: pluggable layout engines and an instanced Three.js renderer",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --clean && tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "d3-force-3d": "^3.0.6"
  },
  "peerDependencies": {
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@types/three": "^0.185.1",
    "jsdom": "^29.1.1",
    "tsup": "^8.3.5",
    "vitest": "^4.1.10"
  }
}
