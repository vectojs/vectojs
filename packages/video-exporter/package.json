{
  "name": "@vectojs/video-exporter",
  "version": "0.2.2",
  "description": "Video export utility for VectoJS",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "vecto-export": "dist/cli.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "prepack": "bun run build && node scripts/verify-package.js",
    "test": "vitest run",
    "verify:package": "bun run build && node scripts/verify-package.js && node scripts/smoke-package.js"
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "puppeteer": "^22.12.1",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^26.1.0",
    "@vectojs/core": "workspace:*",
    "@vectojs/ui": "workspace:*",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
