{
  "name": "@vecto-ui/three",
  "version": "0.2.0",
  "description": "WebGL/Three.js rendering backend for VectoUI",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean"
  },
  "peerDependencies": {
    "@vecto-ui/core": ">=0.8.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@vecto-ui/core": "workspace:*",
    "@types/three": "^0.160.0",
    "tsup": "^8.3.5",
    "vitest": "^4.1.9"
  }
}
