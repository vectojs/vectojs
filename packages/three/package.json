{
  "name": "@vectojs/three",
  "version": "0.1.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "WebGL/Three.js rendering backend for VectoJS",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "(cd ../core && bun run build) && tsup src/index.ts --format cjs,esm --clean && tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@vectojs/core": ">=0.1.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@vectojs/core": "workspace:*",
    "@types/three": "^0.160.0",
    "tsup": "^8.3.5",
    "vitest": "^4.1.9"
  }
}
