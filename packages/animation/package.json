{
  "name": "@vectojs/animation",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Standalone animation drivers and easing functions for VectoJS: tween and spring drivers over a shared easing library.",
  "keywords": [
    "animation",
    "easing",
    "tween",
    "spring",
    "vectojs",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vectojs/vectojs.git",
    "directory": "packages/animation"
  },
  "bugs": {
    "url": "https://github.com/vectojs/vectojs/issues"
  },
  "homepage": "https://github.com/vectojs/vectojs#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --external @vectojs/math --clean && tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@vectojs/math": "^0.1.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^4.1.10"
  }
}
