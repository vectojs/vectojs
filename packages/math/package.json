{
  "name": "@vectojs/math",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Standalone spatial and physics math utilities for VectoJS: spatial hash grid broad-phase and spring physics.",
  "keywords": [
    "spatial-hash",
    "broad-phase",
    "spring-physics",
    "vectojs",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vectojs/vectojs.git",
    "directory": "packages/math"
  },
  "bugs": {
    "url": "https://github.com/vectojs/vectojs/issues"
  },
  "homepage": "https://github.com/vectojs/vectojs#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --clean && tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^4.1.10"
  }
}
