{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules",
    "dist",
    "build",
    "pnpm-lock.yaml",
    "bun.lockb",
    ".DS_Store",
    "tmp/",
    "docs/"
  ]
}
