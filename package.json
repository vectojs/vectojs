{
  "name": "vectojs-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '@vectojs/core' build && bun run --filter '@vectojs/ui' build && bun run --filter '@vectojs/three' build",
    "test": "bun run --filter '@vectojs/*' test",
    "format": "prettier --write \"**/*.{js,ts,json,md,html,yaml}\"",
    "lint": "oxlint --deny-warnings",
    "knip": "knip",
    "benchmark": "bun run scripts/benchmark.ts",
    "compare": "bun run scripts/compare-pretext.ts",
    "compare:dom": "bun run scripts/compare-dom.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "husky": "^9.1.7",
    "knip": "^6.20.0",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.71.0",
    "prettier": "^3.2.5",
    "typescript": "^6.0.3"
  }
}
